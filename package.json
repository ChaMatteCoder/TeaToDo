{
  "name": "teatodo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "lint": "tsc -b --pretty false",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "audit:prod": "npm audit --omit=dev",
    "qa": "npm run lint && npm run audit:prod && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.1",
    "date-fns": "4.1.0",
    "framer-motion": "12.38.0",
    "lucide-react": "1.14.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "^7.14.2",
    "vite": "8.0.10"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "postcss": "8.5.13",
    "tailwindcss": "3.4.19",
    "typescript": "6.0.3"
  }
}
